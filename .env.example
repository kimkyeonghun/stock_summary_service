APP_ENV=dev
DB_PATH=data/stock_mvp.db
COLLECT_INTERVAL_MIN=60
ENABLE_SCHEDULER=false
COLLECT_SCHEDULE_KST=00:00,06:00,12:00,18:00
MORNING_BRIEF_TIME_KST=07:00
UNIVERSE_REFRESH_DAY_OF_MONTH=1
UNIVERSE_REFRESH_TIME_KST=05:30
CRAWLER_MAX_RETRIES=1
OPS_ERROR_ALERT_THRESHOLD=5
ENABLE_TELEGRAM_ERROR_ALERT=false
REQUEST_TIMEOUT_SEC=10
VERIFY_SSL=true
CA_BUNDLE_PATH=
NEWS_PER_STOCK=20
REPORTS_PER_STOCK=10
NAVER_NEWS_PER_STOCK=20
HANKYUNG_REPORTS_PER_STOCK=8
NAVER_FINANCE_REPORTS_PER_STOCK=8
SEC_REPORTS_PER_STOCK=6
SUMMARY_LOOKBACK_DAYS=7
CONSENSUS_COOKIE=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SEC_USER_AGENT=stock-mvp/0.1 (contact: your-email@example.com)
