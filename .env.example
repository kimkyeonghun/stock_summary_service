REQUEST_TIMEOUT_SEC=10
VERIFY_SSL=true
CA_BUNDLE_PATH=
NEWS_PER_STOCK=20
REPORTS_PER_STOCK=10
NAVER_NEWS_PER_STOCK=20
NAVER_FINANCE_REPORTS_PER_STOCK=8
SEC_REPORTS_PER_STOCK=6
SUMMARY_LOOKBACK_DAYS=7
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
